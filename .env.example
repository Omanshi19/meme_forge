# ─────────────────────────────────────────────
# MemeForge AI — Environment Variables
# Copy this file to .env.local (frontend) and .env (backend)
# ─────────────────────────────────────────────

# ── AI ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OR use OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here

# ── Database ────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/memeforge?retryWrites=true&w=majority
MONGODB_DB_NAME=memeforge

# ── Backend ─────────────────────────────────
BACKEND_URL=http://localhost:8000
BACKEND_SECRET_KEY=supersecretkey_change_in_production

# ── Frontend (Next.js — prefix with NEXT_PUBLIC_ for browser access) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth ────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── Image Storage (optional: Cloudinary) ────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ── Imgflip API (free meme template source) ─
IMGFLIP_USERNAME=your_imgflip_username
IMGFLIP_PASSWORD=your_imgflip_password
